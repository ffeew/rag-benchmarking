API_BEARER_TOKEN=change-me-local-token
# Set to true to boot without live OpenRouter / Z.AI keys (mock providers;
# useful for first-run smoke tests). When false the Settings validator
# requires OPENROUTER_API_KEY, ZAI_API_KEY, plus ZAI_CHAT_MODEL,
# ZAI_JUDGE_MODEL, OPENROUTER_EMBEDDING_MODEL, OPENROUTER_RERANK_MODEL.
# MISTRAL_API_KEY is optional: when unset, parse_pdf transparently falls back
# to docling (and then pypdf) for PDF parsing.
ALLOW_MOCK_PROVIDERS=false

# DEBUG restores per-batch ingestion traces; INFO keeps a readable one-line-per-doc view.
LOG_LEVEL=INFO
# auto = colored console when stdout is a TTY, JSON otherwise. Override with json or console.
LOG_FORMAT=auto

DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/rag
REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
# Host the browser uses for presigned URLs. Leave unset to reuse
# MINIO_ENDPOINT (only correct when API and browser share a host).
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
RAW_DOCUMENT_BUCKET=sec-filings
ARTIFACT_BUCKET=sec-filings

OPENROUTER_API_KEY=
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
OPENROUTER_RERANK_MODEL=cohere/rerank-v3.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=RAG Benchmark
OPENROUTER_CHAT_MODEL=openrouter/owl-alpha

# Retrieval-agent tool-call budget. Was 4; raised to 8 so multi-part /
# cross-company queries that legitimately need >4 retrieves to cover all
# sub-claims aren't unfairly capped vs single_pass / llm_only. Field
# constraint in rag_common.config: ge=1, le=8.
RETRIEVAL_AGENT_TOOL_CALL_BUDGET=8

ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_CHAT_MODEL=glm-4.7
ZAI_JUDGE_MODEL=glm-4.7
ZAI_TIMEOUT_SECONDS=60

MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_TIMEOUT_SECONDS=120

LOCAL_CORPUS_PATH=/app/sec_filings_pdf
CORS_ORIGINS=http://localhost:3000
FRONTEND_DIST_PATH=/app/frontend/dist

EVAL_RUN_RAGAS=true
EVAL_MAX_INFLIGHT=1

# Sweeper threshold: a RUNNING job is only marked failed after this many
# seconds without a heartbeat commit. Set comfortably above the per-case
# eval_timeout_seconds=1800 cap so the sweeper only fires on truly stuck
# workers, not on legitimately-slow eval cases stuck on provider retries.
RUNNING_HEARTBEAT_SECONDS=2700
