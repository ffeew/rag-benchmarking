API_BEARER_TOKEN=change-me-local-token
ENVIRONMENT=local
ALLOW_MOCK_PROVIDERS=true

DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/rag
REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
RAW_DOCUMENT_BUCKET=sec-filings
ARTIFACT_BUCKET=sec-filings

OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=openai/gpt-4.1-mini
OPENROUTER_JUDGE_MODEL=openai/gpt-4.1-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_RERANK_MODEL=cohere/rerank-v3.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SEC Filings RAG Benchmark

MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_TIMEOUT_SECONDS=120

LOCAL_CORPUS_PATH=/app/sec_filings_pdf
CORS_ORIGINS=http://localhost:3000
FRONTEND_DIST_PATH=/app/frontend/dist
